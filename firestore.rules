rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerField() {
      return isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function isResourceOwner() {
      return isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /usuarios/{userId} {
      allow read, create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /tarefas/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /tarefas_pessoais/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /feedbacks/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /reunioes/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /alunos/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /aulas/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /custos/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /viagens/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /receitas/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /chat_logs/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /carreira_analises/{userId} {
      allow read, create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Gamification & Development ───────────────────────────────────────────
    match /gamification_profiles/{userId} {
      allow read, create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /development_items/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /user_challenges/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /user_goals_career/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /saved_jobs/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    // ── Investments module ────────────────────────────────────────────────────
    match /user_investments/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /investment_daily_snapshots/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    match /investment_ai_insights/{docId} {
      allow read, update, delete: if isResourceOwner();
      allow create: if isOwnerField();
    }

    // Cache de mercado: qualquer usuário autenticado pode ler e escrever
    match /investment_market_snapshots/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
